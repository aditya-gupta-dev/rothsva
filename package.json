{
  "name": "zapisi",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run dev:backend & bun run dev:web",
    "dev:web": "bun run --filter web dev",
    "dev:backend": "bun run --filter backend start",
    "build:web": "bun run --filter web build",
    "lint:web": "bun run --filter web lint",
